    {
        "id": "172245d468e0a128",
        "type": "function",
        "z": "f30bcbc17b591f22",
        "name": "Parse & Generate SQL Query",
        "func": "let data = msg.payload; \n\nif (!data || (typeof data === \"string\" && data.trim() === \"\")) return null;\n\nif (typeof data === \"string\") {\n    try { data = JSON.parse(data); } \n    catch (e) { return null; }\n}\n\nlet topicParts = msg.topic ? msg.topic.split(\"/\") : [];\nlet deviceId = data.id || data.device_id || topicParts[2] || \"UNKNOWN\";\n\n// Pastikan properti ID konsisten\ndata.id = deviceId;\ndata.device_id = deviceId;\n\n// === KONVERSI UPTIME KE JAM ===\nif (data.uptime !== undefined) {\n    data.uptime = parseFloat((data.uptime / 3600).toFixed(1)); \n} else {\n    data.uptime = 0;\n}\n\nif (data.uptime >= 10000) {\n    data.health = \"Need Maintenance\";\n} else if (data.uptime >= 8000) {\n    data.health = \"Warning\";\n} else {\n    data.health = \"Healthy\";\n}\n\nconst sector = data.sector || 'Sektor 2 (Kertajaya - Depan ITS)';\nconst lat = data.lat || -7.279315;\nconst lng = data.lng || 112.789253;\nconst volt = data.volt || 0;\nconst current = data.current || 0;\nconst power = data.power || (volt * current);\n\n// === 1. QUERY TUNGGAL CTE (Auto Insert Device + Insert Telemetry) ===\nmsg.query = `\n    WITH auto_register_device AS (\n        INSERT INTO devices (device_id, sector_name, latitude, longitude, max_lifespan)\n        VALUES ($1, $2, $3, $4, 10000)\n        ON CONFLICT (device_id) DO NOTHING\n    )\n    INSERT INTO telemetry_logs (device_id, volt, current, power, uptime, created_at) \n    VALUES ($1, $5, $6, $7, $8, NOW());\n`;\n\n// === 2. PARAMETER UTUK POSTGRESQL ===\nmsg.params = [\n    deviceId,     // $1\n    sector,       // $2\n    lat,          // $3\n    lng,          // $4\n    volt,         // $5\n    current,      // $6\n    power,        // $7\n    data.uptime   // $8\n];\n\n// === 3. PERTAHANKAN PAYLOAD BERBENTUK JSON UNTUK WEBSOCKET DASHBOARD ===\nmsg.payload = data; \n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 660,
        "y": 140,
