    {
        "id": "6a11b6f9dd3cfe32",
        "type": "function",
        "z": "f30bcbc17b591f22",
        "name": "Evaluasi & Build Query Alert",
        "func": "let d = msg.payload;\n\nif (!d) return [null, null];\n\nif (typeof d === \"string\") {\n    try { d = JSON.parse(d); } catch (e) { return [null, null]; }\n}\n\nconst deviceId = d.id || d.device_id || \"UNKNOWN\";\nconst volt = parseFloat(d.volt) || 0;\nconst current = parseFloat(d.current) || 0;\nconst power = parseFloat(d.power) || parseFloat((volt * current).toFixed(2));\n\nlet alertData = null;\n\n// Evaluasi Threshold Alert\nif (volt > 240) {\n    alertData = {\n        level: 'Critical',\n        title: 'Lonjakan Tegangan',\n        alertType: 'voltage_spike',\n        message: `Node ${deviceId} terdeteksi lonjakan tegangan sebesar ${volt}V, melebihi batas aman 240V.`,\n        threshold_info: 'V: 240V'\n    };\n} else if (volt > 0 && volt < 200) {\n    alertData = {\n        level: 'Critical',\n        title: 'Perangkat Offline / Tegangan Low',\n        alertType: 'offline',\n        message: `Node ${deviceId} terdeteksi tegangan jauh di bawah batas operasional (${volt}V).`,\n        threshold_info: 'V: 200V'\n    };\n} else if (current > 1.5) {\n    alertData = {\n        level: 'Critical',\n        title: 'Lonjakan Arus',\n        alertType: 'current_spike',\n        message: `Node ${deviceId} mendeteksi lonjakan arus listrik sebesar ${current}A.`,\n        threshold_info: 'I: 1.5A'\n    };\n}\n\nif (alertData) {\n    const sql = `INSERT INTO alerts (device_id, level, title, message, volt, current, power, threshold_info, is_read, created_at) VALUES ('${deviceId}', '${alertData.level}', '${alertData.title}', '${alertData.message}', ${volt}, ${current}, ${power}, '${alertData.threshold_info}', FALSE, NOW()) RETURNING *;`;\n\n    // Output 1: Khusus PostgreSQL (Mengarahkan msg.payload & msg.query)\n    const dbMsg = {\n        payload: sql,\n        query: sql\n    };\n\n    // Output 2: Khusus WebSocket Dashboard\n    const wsMsg = {\n        payload: {\n            id: deviceId,\n            alert: true,\n            alertType: alertData.alertType,\n            level: alertData.level,\n            title: alertData.title,\n            message: alertData.message,\n            volt: volt,\n            current: current,\n            power: power,\n            threshold_info: alertData.threshold_info\n        }\n    };\n\n    return [dbMsg, wsMsg];\n}\n\nreturn [null, null];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
