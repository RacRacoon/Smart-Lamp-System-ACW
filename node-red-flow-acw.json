        "id": "dcf888a13551931a",
        "type": "function",
        "z": "f30bcbc17b591f22",
        "name": "Format Chart.js Structure",
        "func": "let rows = msg.payload || [];\n\nlet result = {\n    labels: [],\n    volt: [],\n    current: [],\n    power: []\n};\n\nrows.forEach(row => {\n    result.labels.push(row.time_label);\n    result.volt.push(parseFloat(row.volt) || 0);\n    result.current.push(parseFloat(row.ampere) || 0);\n    result.power.push(parseFloat(row.watt) || 0);\n});\n\nmsg.payload = result;\nreturn msg;",
