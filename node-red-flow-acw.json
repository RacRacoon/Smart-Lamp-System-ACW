    {
        "id": "9ef91f938d6115cd",
        "type": "function",
        "z": "f30bcbc17b591f22",
        "name": "Prepare SQL Query",
        "func": "let deviceId = msg.req.query.device_id || 'L-101';\n\nmsg.query = `\n    SELECT \n        TO_CHAR(created_at, 'HH24:MI') as time_label,\n        volt,\n        current as ampere,\n        power as watt\n    FROM (\n        SELECT created_at, volt, current, power\n        FROM telemetry_logs\n        WHERE device_id = $1\n        ORDER BY created_at DESC\n        LIMIT 100\n    ) sub\n    ORDER BY created_at ASC;\n`;\nmsg.params = [deviceId];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
